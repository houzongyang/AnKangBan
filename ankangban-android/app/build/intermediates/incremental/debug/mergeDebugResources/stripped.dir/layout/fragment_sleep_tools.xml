<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#F5F5F5"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_arrow_back"
                    app:tint="#333333" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_toEndOf="@id/btnBack"
                    android:layout_marginStart="16dp"
                    android:text="助眠工具"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#333333" />

                <TextView
                    android:id="@+id/tvUserPoints"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toStartOf="@id/btnDarkMode"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="16dp"
                    android:text="🏆 120"
                    android:textColor="#FF9800"
                    android:textStyle="bold"
                    android:background="@drawable/bg_rounded_8dp"
                    android:backgroundTint="#FFF3E0"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp"/>

                <ImageView
                    android:id="@+id/btnDarkMode"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="16dp"
                    android:src="@drawable/ic_waves"
                    app:tint="#616161" />

            </RelativeLayout>
        </androidx.appcompat.widget.Toolbar>

        <!-- Scene Switcher Removed -->

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Tools Grid -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2"
                android:useDefaultMargins="true">

                <!-- 1. AI Content -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardAiTool"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_marginEnd="8dp"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="#FFF3E0"
                    app:strokeWidth="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_ai_stars"
                            app:tint="#FF9800"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AI 助眠生成"
                            android:textStyle="bold"
                            android:layout_marginTop="8dp"
                            android:textColor="#333333"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="专属故事/冥想"
                            android:textSize="12sp"
                            android:textColor="#616161"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 2. White Noise -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardWhiteNoise"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_marginStart="8dp"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="#E8F5E9"
                    app:strokeWidth="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_music_note"
                            app:tint="#4CAF50"/>
                        <TextView
                            android:id="@+id/badgeWhiteNoise"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="推荐"
                            android:background="#FF4081"
                            android:textColor="@color/white"
                            android:textSize="10sp"
                            android:paddingHorizontal="4dp"
                            android:paddingVertical="1dp"
                            android:visibility="gone"
                            tools:visibility="visible"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="白噪音"
                            android:textStyle="bold"
                            android:layout_marginTop="8dp"
                            android:textColor="#333333"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="雨声/海浪/ASMR"
                            android:textSize="12sp"
                            android:textColor="#616161"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 3. Breathing -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardBreathing"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_marginEnd="8dp"
                    android:layout_marginTop="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="#E3F2FD"
                    app:strokeWidth="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_forest"
                            app:tint="#2196F3"/>
                        <TextView
                            android:id="@+id/badgeBreathing"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="推荐"
                            android:background="#FF4081"
                            android:textColor="@color/white"
                            android:textSize="10sp"
                            android:paddingHorizontal="4dp"
                            android:paddingVertical="1dp"
                            android:visibility="gone"
                            tools:visibility="visible"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="呼吸训练"
                            android:textStyle="bold"
                            android:layout_marginTop="8dp"
                            android:textColor="#333333"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="4-7-8 呼吸法"
                            android:textSize="12sp"
                            android:textColor="#616161"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 4. Meditation -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardMeditation"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="#F3E5F5"
                    app:strokeWidth="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_heart"
                            app:tint="#9C27B0"/>
                        <TextView
                            android:id="@+id/badgeMeditation"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="推荐"
                            android:background="#FF4081"
                            android:textColor="@color/white"
                            android:textSize="10sp"
                            android:paddingHorizontal="4dp"
                            android:paddingVertical="1dp"
                            android:visibility="gone"
                            tools:visibility="visible"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="冥想课程"
                            android:textStyle="bold"
                            android:layout_marginTop="8dp"
                            android:textColor="#333333"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="身体扫描/放松"
                            android:textSize="12sp"
                            android:textColor="#616161"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </GridLayout>

            <!-- AI Generator Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white"
                app:strokeWidth="0dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✨ 混元AI 助眠内容定制"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#673AB7"/>
                        <Space android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
                        <TextView
                            android:id="@+id/btnAiHistory"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="历史记录"
                            android:textColor="#9E9E9E"
                            android:textSize="12sp"
                            android:padding="8dp"
                            android:background="?attr/selectableItemBackground"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="16dp">
                        
                        <com.google.android.material.chip.ChipGroup
                            android:id="@+id/chipGroupType"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            app:singleSelection="true">
                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipStory"
                                style="@style/Widget.Material3.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:checked="true"
                                android:text="助眠故事"/>
                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipMeditation"
                                style="@style/Widget.Material3.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="冥想引导"/>
                        </com.google.android.material.chip.ChipGroup>
                    </LinearLayout>

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none"
                        android:layout_marginBottom="16dp">
                        <com.google.android.material.chip.ChipGroup
                            android:id="@+id/chipGroupTags"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:singleLine="true">
                            <com.google.android.material.chip.Chip
                                style="@style/Widget.Material3.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="自然音效"
                                android:checked="true"/>
                            <com.google.android.material.chip.Chip
                                style="@style/Widget.Material3.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="舒缓放松"/>
                            <com.google.android.material.chip.Chip
                                style="@style/Widget.Material3.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="沉浸式"/>
                            <com.google.android.material.chip.Chip
                                style="@style/Widget.Material3.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="温暖治愈"/>
                        </com.google.android.material.chip.ChipGroup>
                    </HorizontalScrollView>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGenerate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="生成专属内容"
                        android:textSize="16sp"
                        android:padding="12dp"
                        app:icon="@drawable/ic_ai_stars"
                        app:iconGravity="textStart"
                        app:backgroundTint="#673AB7"/>

                    <!-- Result Area -->
                    <LinearLayout
                        android:id="@+id/layoutAiResult"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"
                        android:layout_marginTop="16dp"
                        android:padding="12dp"
                        android:background="@drawable/bg_rounded_8dp"> <!-- Assuming bg exists or just use color -->
                        
                        <TextView
                            android:id="@+id/tvAiTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="森林奇遇"
                            android:textStyle="bold"
                            android:textColor="#4A148C"/>
                            
                        <TextView
                            android:id="@+id/tvAiContent"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="故事内容..."
                            android:maxLines="3"
                            android:ellipsize="end"
                            android:textColor="#616161"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:layout_marginTop="8dp">
                            <ImageView
                                android:id="@+id/btnPlayAi"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:src="@drawable/ic_play_circle_filled"
                                app:tint="#673AB7"/>
                            <SeekBar
                                android:id="@+id/seekBarAi"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:progress="0"
                                android:max="100"/>
                            <TextView
                                android:id="@+id/tvAiTimer"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="00:00"
                                android:textSize="12sp"
                                android:textColor="#616161"/>
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Loading Overlay -->
    <FrameLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80FFFFFF"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">
        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"/>
    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
