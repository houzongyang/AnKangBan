<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_rounded_top_16dp"
    android:backgroundTint="#FFFFFF"
    android:paddingBottom="24dp">

    <!-- Handle Bar -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:background="#E0E0E0"
        android:backgroundTint="#E0E0E0" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="白噪音"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:gravity="center"
        android:padding="16dp"/>

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="4"
        android:padding="16dp"
        android:alignmentMode="alignMargins">

        <!-- Item 1: Rain -->
        <LinearLayout
            android:id="@+id/itemRain"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:background="?attr/selectableItemBackground">
            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_water_drop"
                app:tint="#607D8B"
                android:background="@drawable/shape_circle_gradient"
                android:backgroundTint="#E3F2FD"
                android:padding="10dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="雨声"
                android:layout_marginTop="8dp"
                android:textColor="#333333"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- Item 2: Ocean -->
        <LinearLayout
            android:id="@+id/itemOcean"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:background="?attr/selectableItemBackground">
            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_waves"
                app:tint="#0288D1"
                android:background="@drawable/shape_circle_gradient"
                android:backgroundTint="#E1F5FE"
                android:padding="10dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="海浪"
                android:layout_marginTop="8dp"
                android:textColor="#333333"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- Item 3: Forest -->
        <LinearLayout
            android:id="@+id/itemForest"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:background="?attr/selectableItemBackground">
            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_forest"
                app:tint="#4CAF50"
                android:background="@drawable/shape_circle_gradient"
                android:backgroundTint="#E8F5E9"
                android:padding="10dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="森林"
                android:layout_marginTop="8dp"
                android:textColor="#333333"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- Item 4: ASMR -->
        <LinearLayout
            android:id="@+id/itemAsmr"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:background="?attr/selectableItemBackground">
            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_spa"
                app:tint="#9C27B0"
                android:background="@drawable/shape_circle_gradient"
                android:backgroundTint="#F3E5F5"
                android:padding="10dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ASMR"
                android:layout_marginTop="8dp"
                android:textColor="#333333"
                android:textSize="12sp"/>
        </LinearLayout>

    </GridLayout>

    <!-- Playback Controls -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardPlayer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp"
        app:cardBackgroundColor="#FAFAFA"
        app:cardCornerRadius="12dp"
        app:strokeColor="#EEEEEE"
        app:strokeWidth="1dp"
        app:cardElevation="0dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/ivCurrentIcon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_music_note"
                app:tint="#673AB7"
                android:background="@drawable/bg_rounded_8dp"
                android:backgroundTint="#EDE7F6"
                android:padding="8dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">
                <TextView
                    android:id="@+id/tvCurrentName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="未播放"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:textSize="14sp"/>
                <TextView
                    android:id="@+id/tvTimerStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="点击图标选择声音"
                    android:textColor="#757575"
                    android:textSize="12sp"/>
            </LinearLayout>

            <ImageView
                android:id="@+id/btnTimer"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_clock"
                app:tint="#757575"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="4dp"
                android:layout_marginEnd="8dp"/>

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/btnPlayPause"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:fabSize="mini"
                app:elevation="0dp"
                app:backgroundTint="#673AB7"
                app:tint="#FFFFFF"
                android:src="@drawable/ic_play_arrow"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>