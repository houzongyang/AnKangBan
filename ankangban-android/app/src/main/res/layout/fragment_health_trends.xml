<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="?android:attr/colorBackground">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="24dp">

        <!-- Top Bar -->
        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggleGroupDimension"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="8dp"
            app:singleSelection="true"
            app:selectionRequired="true"
            app:checkedButton="@id/btnDay"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnExport"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constrainedWidth="true">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDay"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="日" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnWeek"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="周" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMonth"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="月" />
        </com.google.android.material.button.MaterialButtonToggleGroup>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnExport"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="导出"
            android:textColor="?attr/colorPrimary"
            app:icon="@android:drawable/ic_menu_save"
            app:iconTint="?attr/colorPrimary"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"/>

        <Spinner
            android:id="@+id/spinnerDataType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnExport" />

        <!-- Chart Area -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardChart"
            android:layout_width="0dp"
            android:layout_height="350dp"
            android:layout_margin="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/spinnerDataType">

            <com.ankangban.health.ui.view.HealthChartView
                android:id="@+id/chartView"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Stats Area -->
        <GridLayout
            android:id="@+id/gridStats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:columnCount="3"
            android:rowCount="1"
            app:layout_constraintTop_toBottomOf="@id/cardChart"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:gravity="center"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="平均"
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="12sp"/>
                <TextView
                    android:id="@+id/tvStatAvg"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="?android:attr/textColorPrimary"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:gravity="center"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="最高"
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="12sp"/>
                <TextView
                    android:id="@+id/tvStatMax"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#F44336"/>
            </LinearLayout>
            
             <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:gravity="center"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="最低"
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="12sp"/>
                <TextView
                    android:id="@+id/tvStatMin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#2196F3"/>
            </LinearLayout>

        </GridLayout>

        <!-- AI Insight Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAiInsight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#F3E5F5"
            app:contentPadding="16dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/gridStats"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_dialog_info"
                        app:tint="#673AB7"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AI 睡眠趋势洞察"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="#673AB7"
                        android:layout_marginStart="8dp"/>
                    <Space
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"/>
                    <ProgressBar
                        android:id="@+id/pbAiLoading"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:indeterminate="true"
                        android:visibility="gone"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvAiSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="正在生成智能分析..."
                    android:layout_marginTop="8dp"
                    android:textColor="#424242"/>

                <TextView
                    android:id="@+id/tvAiAbnormalities"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="异常点："
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"
                    android:textColor="#D32F2F"
                    android:visibility="gone"/>

                <TextView
                    android:id="@+id/tvAiSuggestions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="改善建议："
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"
                    android:textColor="#388E3C"
                    android:visibility="gone"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Footer Buttons -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBack"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="32dp"
            android:text="返回监测"
            app:layout_constraintTop_toBottomOf="@id/cardAiInsight"
            app:layout_constraintEnd_toEndOf="parent" />
            
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="数据缓存至本地，仅展示近30天健康数据"
            android:textSize="10sp"
            android:textColor="#9E9E9E"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/btnBack"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>