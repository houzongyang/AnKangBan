<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/scrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dashboard_bg"
    android:fillViewport="true"
    android:clipToPadding="false"
    android:paddingBottom="150dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="50dp">

        <!-- Top Bar -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/topBar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@color/dashboard_bg"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/ivLogo"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="16dp"
                android:src="@mipmap/ic_launcher_round"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvAppTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:fontFamily="sans-serif-medium"
                android:text="安康伴-日常监测"
                android:textColor="@color/dashboard_text_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/ivLogo"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/ivSyncStatus"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginEnd="16dp"
                android:src="@drawable/ic_sync"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/dashboard_success"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/dashboard_stroke"
                app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Core Data Area -->
        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guideCoreBottom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.55" />

        <!-- Heart Rate Card (Left Large) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardHeartRate"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeColor="@color/dashboard_stroke"
            app:strokeWidth="1dp"
            app:layout_constraintBottom_toTopOf="@id/guideCoreBottom"
            app:layout_constraintEnd_toStartOf="@id/guideVertical"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/topBar">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvHeartRateTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="实时心率"
                    android:textColor="@color/dashboard_text_secondary"
                    android:textSize="14sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_heart"
                    app:tint="@color/dashboard_error"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Circular Progress -->
                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/progressHeartRate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:max="200"
                    android:progress="72"
                    app:indicatorColor="@color/dashboard_success"
                    app:trackColor="@color/dashboard_stroke"
                    app:indicatorSize="140dp"
                    app:trackThickness="4dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvHeartRateTitle" />

                <TextView
                            android:id="@+id/tvHeartRateValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="@color/dashboard_success"
                            android:textSize="48sp"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="@id/progressHeartRate"
                            app:layout_constraintEnd_toEndOf="@id/progressHeartRate"
                            app:layout_constraintStart_toStartOf="@id/progressHeartRate"
                            app:layout_constraintTop_toTopOf="@id/progressHeartRate"
                            app:layout_constraintVertical_bias="0.4" />

                        <TextView
                            android:id="@+id/tvHeartRateUnit"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="次/分"
                            android:textColor="@color/dashboard_text_secondary"
                            android:textSize="12sp"
                            app:layout_constraintTop_toBottomOf="@id/tvHeartRateValue"
                            app:layout_constraintEnd_toEndOf="@id/progressHeartRate"
                            app:layout_constraintStart_toStartOf="@id/progressHeartRate" />

                        <TextView
                            android:id="@+id/tvRestingHeartRate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="静息: --"
                            android:textColor="@color/dashboard_text_secondary"
                            android:textSize="12sp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent" />

                 <TextView
                    android:id="@+id/tvHeartRateWarning"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="预警: 50-120"
                    android:textColor="@color/dashboard_text_secondary"
                    android:textSize="12sp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guideVertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.66" />

        <!-- Right Side Cards Container -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:orientation="vertical"
            android:weightSum="2"
            app:layout_constraintBottom_toTopOf="@id/guideCoreBottom"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/guideVertical"
            app:layout_constraintTop_toBottomOf="@id/topBar">

            <!-- SpO2 Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSpo2"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_margin="16dp"
                android:layout_marginBottom="8dp"
                android:layout_weight="1"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/dashboard_stroke"
                app:strokeWidth="1dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="血氧"
                        android:textSize="14sp"
                        android:textColor="@color/dashboard_text_secondary"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"/>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_water_drop"
                        app:tint="@color/dashboard_primary"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"/>

                    <TextView
                                android:id="@+id/tvSpo2Value"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--%"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:textColor="@color/dashboard_primary"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintStart_toStartOf="parent"/>

                        </androidx.constraintlayout.widget.ConstraintLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Temp Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardTemp"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_margin="16dp"
                        android:layout_marginTop="8dp"
                        android:layout_weight="1"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="2dp"
                        app:strokeColor="@color/dashboard_stroke"
                        app:strokeWidth="1dp">

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="腕温"
                                android:textSize="14sp"
                                android:textColor="@color/dashboard_text_secondary"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent"/>

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_thermometer"
                                app:tint="@color/dashboard_warning"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toTopOf="parent"/>

                            <TextView
                                android:id="@+id/tvTempValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--℃"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:textColor="@color/dashboard_warning"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintStart_toStartOf="parent"/>

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- Auxiliary Data Area -->
        <HorizontalScrollView
            android:id="@+id/scrollViewAux"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:clipToPadding="false"
            android:scrollbars="none"
            app:layout_constraintTop_toBottomOf="@id/guideCoreBottom">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Steps Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardSteps"
                    android:layout_width="200dp"
                    android:layout_height="wrap_content"
                    android:minHeight="140dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeColor="@color/dashboard_stroke"
                    app:strokeWidth="1dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="16dp">
                        
                        <TextView
                            android:id="@+id/tvStepsTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="今日步数"
                            android:textColor="@color/dashboard_text_secondary"
                            android:textSize="14sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"/>

                        <TextView
                                    android:id="@+id/tvStepsValue"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="--"
                                    android:textSize="24sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/dashboard_text_primary"
                                    app:layout_constraintStart_toStartOf="parent"
                                    app:layout_constraintTop_toBottomOf="@id/tvStepsTitle"
                                    android:layout_marginTop="8dp"/>

                                <com.google.android.material.progressindicator.LinearProgressIndicator
                                    android:id="@+id/progressSteps"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    app:indicatorColor="@color/dashboard_primary"
                                    app:trackColor="@color/dashboard_stroke"
                                    app:trackThickness="6dp"
                                    app:trackCornerRadius="3dp"
                                    android:progress="0"
                                    app:layout_constraintTop_toBottomOf="@id/tvStepsValue"/>

                                <TextView
                                    android:id="@+id/tvCalories"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="-- kcal"
                                    android:textSize="12sp"
                                    android:textColor="@color/dashboard_text_secondary"
                                    android:layout_marginTop="8dp"
                                    app:layout_constraintTop_toBottomOf="@id/progressSteps"
                                    app:layout_constraintStart_toStartOf="parent"/>

                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Sleep Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardSleep"
                    android:layout_width="200dp"
                    android:layout_height="wrap_content"
                    android:minHeight="140dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeColor="@color/dashboard_stroke"
                    app:strokeWidth="1dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/tvSleepTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="昨日睡眠"
                            android:textColor="@color/dashboard_text_secondary"
                            android:textSize="14sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:id="@+id/tvSleepEfficiency"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="效率 --%"
                            android:textColor="@color/dashboard_primary"
                            android:textSize="14sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/tvSleepTitle" />

                        <TextView
                            android:id="@+id/tvSleepDuration"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="--小时"
                            android:textColor="@color/dashboard_text_primary"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/tvSleepEfficiency" />

                        <TextView
                            android:id="@+id/tvSleepDetail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="查看详情 >"
                            android:textColor="@color/dashboard_text_tertiary"
                            android:textSize="12sp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent" />

                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Resp Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardResp"
                    android:layout_width="200dp"
                    android:layout_height="wrap_content"
                    android:minHeight="140dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeColor="@color/dashboard_stroke"
                    app:strokeWidth="1dp">
                     <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="16dp">
                         <TextView
                            android:id="@+id/tvRespTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="呼吸率"
                            android:textColor="@color/dashboard_text_secondary"
                            android:textSize="14sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"/>

                        <TextView
                                    android:id="@+id/tvRespValue"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="--次/分"
                                    android:textSize="24sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/dashboard_resp_text"
                                    app:layout_constraintStart_toStartOf="parent"
                                    app:layout_constraintTop_toBottomOf="@id/tvRespTitle"
                                    android:layout_marginTop="8dp"/>
                        
                        <TextView
                            android:id="@+id/tvRespRange"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="正常范围: 12-20"
                            android:textSize="12sp"
                            android:textColor="@color/dashboard_text_secondary"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/tvRespValue"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintVertical_bias="1.0"
                            android:layout_marginTop="8dp"/>
                     </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ECG Card Removed -->

            </LinearLayout>
        </HorizontalScrollView>

        <!-- Bottom Function Area -->
        <Button
            android:id="@+id/btnChronic"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="24dp"
            android:text="慢病管理中心"
            android:textSize="16sp"
            app:icon="@drawable/ic_medication"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            app:cornerRadius="24dp"
            app:backgroundTint="#6750A4"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/scrollViewAux" />

        <Button
            android:id="@+id/btnTrends"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="16dp"
            android:text="数据趋势"
            app:cornerRadius="24dp"
            app:strokeColor="@color/dashboard_primary"
            app:layout_constraintEnd_toStartOf="@id/btnSource"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnChronic" />

        <Button
            android:id="@+id/btnSource"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="16dp"
            android:text="数据源管理"
            app:cornerRadius="24dp"
            app:strokeColor="@color/dashboard_primary"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/btnTrends"
            app:layout_constraintTop_toBottomOf="@id/btnChronic" />

        <Button
            android:id="@+id/btnMedication"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="16dp"
            android:text="@string/title_medication_reminder"
            android:textSize="16sp"
            app:icon="@drawable/ic_medication_24"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            app:cornerRadius="24dp"
            app:backgroundTint="#2196F3"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnTrends" />

        <TextView
            android:id="@+id/tvFooter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="数据来自健康数据接口，实时采集自设备传感器"
            android:textColor="@color/dashboard_text_tertiary"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnMedication" />

        <!-- Bottom Spacer -->
        <View
            android:layout_width="match_parent"
            android:layout_height="100dp"
            app:layout_constraintTop_toBottomOf="@id/tvFooter"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
